# ─────────────────────────────────────────────
# AIOS .gitignore
# Bare-metal x86_64 OS — C / NASM / GCC toolchain
# ─────────────────────────────────────────────

# ── Compiled object files ────────────────────
*.o
*.obj

# ── Static & shared libraries ────────────────
*.a
*.so
*.so.*
*.dylib
*.lib

# ── Compiled binaries / ELF executables ──────
*.elf
*.bin
*.exe
*.out
a.out

# ── Bootloader / raw disk images ─────────────
*.img
*.hdd
*.vhd
*.vdi
*.vmdk
*.raw

# ── ISO images (generated by build.sh) ───────
*.iso
isodir/

# ── Linker map & debug files ─────────────────
*.map
*.sym
*.lst
*.d

# ── NASM listing / dependency files ──────────
*.lst
*.dep

# ── GDB / debugging artifacts ────────────────
*.gdb
gdb.txt
.gdb_history

# ── Build output directories ──────────────────
build/
dist/
out/
isodir/
_build/

# ── Cross-compiler toolchain (local installs) ─
toolchain/
cross/
prefix/

# ── QEMU runtime files ────────────────────────
*.qcow2
*.snapshot
qemu.log

# ── Editor & IDE files ────────────────────────
# VSCode
.vscode/
*.code-workspace

# CLion / JetBrains
.idea/
cmake-build-*/

# Vim/Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ── OS-generated junk ─────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon\r
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# ── Logs & temporary files ────────────────────
*.log
*.tmp
*.temp
*.bak
*.orig
*.rej

# ── Compressed archives ───────────────────────
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.zip
*.7z
*.xz

# ── Python (if any helper scripts exist) ──────
__pycache__/
*.pyc
*.pyo
*.pyd
.env
venv/

# ── Secrets / local config ────────────────────
.env
.env.*
*.secret
local.conf
